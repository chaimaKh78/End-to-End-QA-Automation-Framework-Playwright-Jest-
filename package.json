{
  "name": "taskmanager",
  "version": "1.0.0",
  "private": true,
  "description": "TaskManager - Projet fil rouge CI/CD avec Express, Jest, Playwright et Allure",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "lint": "node -e \"console.log('No lint configured')\"",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:api": "jest tests/api",
    "test:e2e": "playwright test",
    "test:coverage": "jest --coverage",
    "test:all": "npm run test && npm run test:e2e",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "report": "npm run test:all && npm run allure:generate"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "allure-commandline": "^2.38.1",
    "allure-jest": "^3.7.1",
    "allure-playwright": "^3.7.1",
    "jest": "^30.3.0",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
